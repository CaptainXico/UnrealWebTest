# Git LFS configuration for large binary files

# WebAssembly and game data files (large binaries)
# NOTE: GitHub Pages doesn't support LFS, so these files must be stored directly in git
# *.wasm filter=lfs diff=lfs merge=lfs -text
# *.data filter=lfs diff=lfs merge=lfs -text
*.command filter=lfs diff=lfs merge=lfs -text

# Compressed files (if using compression)
*.jsgz filter=lfs diff=lfs merge=lfs -text
*.wasmgz filter=lfs diff=lfs merge=lfs -text
*.datagz filter=lfs diff=lfs merge=lfs -text
*.symbolsgz filter=lfs diff=lfs merge=lfs -text
